# Propstack
PROPSTACK_API_KEY=<PROPSTACK_API_KEY>
PROPSTACK_API_BASE=https://api.propstack.de/v1
PROPSTACK_WEBHOOK_SECRET=<WEBHOOK_SECRET_MIN_32_CHARS>

# WordPress Bridge Plugin
# Basis-URL bis einschl. /sync - der Service haengt /images und /delete an.
WP_BRIDGE_URL=https://tandel.immobilien/staging/wp-json/tandel/v1/sync
WP_BRIDGE_API_KEY=<WP_BRIDGE_API_KEY>

# Service
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Feature flags
SYNC_FULL_API_KEY=<RANDOM_ADMIN_KEY>
